  booktitle = {{{OBPDC}}},
  author = {Chatziantoniou, Panagiotis and Kranitis, Nektarios and Tsigkanos, Antonis},
  date = {2020},
  abstract = {Nowadays, hyperspectral imaging is recognized as a cornerstone remote sensing technology. The explosive growth in image data volume and instrument data rates, compete with limited on-board storage resources and downlink bandwidth, making hyperspectral image data compression a mission critical on-board processing task. In this context, the Consultative Committee for Space Data Systems (CCSDS) extended the previous Lossless standard to Issue 2 for Near-Lossless Hyperspectral image compression. A key feature of CCSDS-123.0-B-2 is the new Hybrid Entropy Coder, which at low bit rates outperforms the Issue 1 entropy coders. In this contribution, we introduce a high-performance hardware implementation of the CCSDS-123.0-B-2 Hybrid Entropy Coder targeting a Xilinx Kintex Ultrascale XQRKU060 space-grade SRAM FPGA, described in portable VHDL RTL. The proposed architecture processes 1 sample per cycle when the high-entropy encoding method is selected and multiple cycles per sample when low-entropy coding is selected, while deep pipelining enables achieving a high clock frequency. Moreover, the proposed architecture exploits the systolic design pattern to provide modularity and latency insensitivity in a elastic pipeline. To the best of our knowledge, this is the first implementation of the CCSDS-123.0-B-2 Hybrid Entropy Coder on a space-grade SRAM FPGA.},
  langid = {english},
  file = {/Users/aasmundnorsett/Zotero/storage/KLYIYALI/Chatziantoniou - A High-Performance RTL Implementation of the CCSDS-123.0-B-2 Hybrid Entropy Coder on a space-grade S.pdf}
