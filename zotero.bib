@article{tsigkanosHighPerformanceCOTSFPGA2020,
  title = {High-{{Performance COTS FPGA SoC}} for {{Parallel Hyperspectral Image Compression With CCSDS-123}}.0-{{B-1}}},
  author = {Tsigkanos, Antonis and Kranitis, Nektarios and Theodoropoulos, Dimitris and Paschalis, Antonios},
  date = {2020-11},
  journaltitle = {IEEE Transactions on Very Large Scale Integration (VLSI) Systems},
  volume = {28},
  number = {11},
  issn = {1557-9999},
  doi = {10.1109/TVLSI.2020.3020164},
  abstract = {Nowadays, hyperspectral imaging is recognized as a cornerstone remote sensing technology. Next generation, high-speed airborne, and space-borne imagers have increased resolution, resulting in an explosive growth in data volume and instrument data rate in the range of gigapixel per second. This competes with limited on-board resources and bandwidth, making hyperspectral image compression a mission critical on-board processing task. At the same time, the “new space” trend is emerging, where launch costs decrease, and agile approaches are exploited building smallsats using commercial-off-the-shelf (COTS) parts. In this contribution, we introduce a high-performance parallel implementation of the CCSDS-123.0-B-1 hyperspectral compression algorithm targeting SRAM field-programmable gate array (FPGA) technology. The architecture exploits image segmentation to provide the robustness to data corruption and enables scalable throughput performance by leveraging segment-level parallelism. Furthermore, we exploit the capabilities of a COTS FPGA system-on-chip (SoC) device to optimize size, weight, power, and cost (SWaP-C). The architecture partitions a hyperspectral cube stored in a DRAM framebuffer into segments, compressing them in parallel using a flexible software scheduler hosted in the SoC CPU and several compressor accelerator cores in the FPGA fabric. A 5-core implementation demonstrated on a Zynq-7045 FPGA achieves a throughput performance of 1387 Msamples/s [22.2 Gb/s at 16 bits per pixel per band (bpppb)] and outperforms previous implementations in equivalent FPGA technology, allowing seamless integration with next-generation hyperspectral sensors.},
  keywords = {Consultative Committee for Space Data Systems (CCSDS),Field programmable gate arrays,field-programmable gate array (FPGA),hyperspectral compression,Hyperspectral imaging,Image coding,Image segmentation,on-board data processing,Performance evaluation,Sensors,system-on-chip (SoC)},
  file = {/Users/aasmundnorsett/Zotero/storage/Q3QEHG5F/Tsigkanos et al. - 2020 - High-Performance COTS FPGA SoC for Parallel Hyperspectral Image Compression With CCSDS-123.0-B-1.pdf}
}

@article{vorhaugDevelopmentIntegrationCCSDS2024,
  title = {Development and {{Integration}} of {{CCSDS}} 123.0-{{B-2 FPGA Accelerator}} for {{HYPSO-1}}},
  author = {Vorhaug, Daniel and Boyle, Samuel and Orlandic, Milica},
  date = {2024},
  doi = {10.5281/zenodo.13889114},
  abstract = {The HYPerspectral imaging small Satellite for Ocean observation (HYPSO) mission uses hyperspectral images to monitor the environment by collecting images of up to hundreds of bands in the electromagnetic spectrum. This mission relies on the use of reconfigurable hardware for acceleration of onboard compression of hyperspectral images. This combats a challenge associated with small satellites as their constrained receive and transfer bandwidths and storage capabilities paired with hyperspectral images introduce limitations in their efficiency. Onboard compression is key in maximising satellite operational capacity by minimising time spent communicating and increasing the number of images that can be stored. The HYPSO-1 satellite currently uses a hyperspectral image compressor; CCSDS 123.0-B-1 standard on a Field-Programmable Gate Array (FPGA) accelerator to compress its hyperspectral images. With the development of a near-lossless CCSDS 123.0-B-2 compliant encoder accelerator, this work has provided state-of-the-art compression speeds for implementations on smaller off-the-shelf FPGAs such as the ZYNQ-7000 series. This work describes the B-2 accelerator, the testing procedure in which upon successful RTL simulations the accelerator was tested on an on-ground HYPSO-1 system model and then passed integration tests in orbit on HYPSO-1, replacing B-1 as the defacto onboard standard in use.},
  langid = {english},
  file = {/Users/aasmundnorsett/Zotero/storage/9XLTFXI6/Vorhaug et al. - Development and Integration of CCSDS 123.0-B-2 FPGA Accelerator for HYPSO-.pdf}
}

@inproceedings{vorhaugHighLevelCCSDS1230B22024,
  title = {High-{{Level CCSDS}} 123.0-{{B-2 Hyperspectral Image Compressor Verification Model}}},
  booktitle = {2024 14th {{Workshop}} on {{Hyperspectral Imaging}} and {{Signal Processing}}: {{Evolution}} in {{Remote Sensing}} ({{WHISPERS}})},
  author = {Vorhaug, Daniel and Boyle, Samuel and Orlandić, Milica},
  date = {2024-12},
  issn = {2158-6276},
  doi = {10.1109/WHISPERS65427.2024.10876459},
  abstract = {Satellite hyperspectral imaging is a powerful tool in global environmental monitoring and a major challenge associated with HyperSpectral Images (HSIs) is their large size. Compression is of key importance in the storage and transmission of HSIs through the reduction of physical image size. The Consultative Committee for Space Data Systems (CCSDS) 123.0-B-2 is the newest issue of the hyperspectral image compression standard supporting lossless and near-lossless compression. In this work a high-level implementation of CCSDS 123.0-B-2 is developed and verified. This high-level model provides outputs between stages of the compression process and is intended to be suitable for supporting the development of hardware accelerators or different software implementations through the availability of these intermediate results of functionalities in the standard. This facilitates implementations that adopt the full or partial standard. This is then verified for different encoder types and all configurable compression settings for two test sets. Furthermore, this framework has been successfully applied in work since by the authors through the verification of a CCSDS B-2 accelerator on FPGA, demonstrating its robustness and applicability.},
  eventtitle = {2024 14th {{Workshop}} on {{Hyperspectral Imaging}} and {{Signal Processing}}: {{Evolution}} in {{Remote Sensing}} ({{WHISPERS}})},
  keywords = {CCSDS-123 compression,hyperspectral imaging,Hyperspectral imaging,Image coding,remote sensing,Robustness,Satellites,Sensors,Signal processing,Software,Standards,Symbols,Throughput,verification model},
  file = {/Users/aasmundnorsett/Zotero/storage/TYVMMLVJ/Vorhaug et al. - 2024 - High-Level CCSDS 123.0-B-2 Hyperspectral Image Compressor Verification Model.pdf}
}

@thesis{vorhaugHyperspectralImageCompression2024,
  type = {mathesis},
  title = {Hyperspectral {{Image Compression Accelerator On FPGA Using CCSDS}} 123.0-{{B-2}}},
  author = {Vorhaug, Daniel},
  date = {2024},
  institution = {NTNU},
  abstract = {Hyperspektral fotografering med satellitter er et sentralt verktøy innen global overvåking av miljøet. Disse satellittene kan ta bilder med data om hundrevis av lysbølgelengder, og størrelsen på disse bildene kan fylle lagringsplassen på satellitten og nedlastingskapasiteten fra den. Datakomprimering kan redusere den nødvendige lagringsplassen og gjøre det mulig å laste ned flere bilder.  HYPSO-1 satellitten bruker en hyperspektral bildekomprimerer etter CCSDS 123.0-B-1 standarden på en Field Programmable Gate Array (FPGA) for å komprimere sine hyperspektrale bilder. En nyere versjon av standarden, CCSDS 123.0-B-2, introduserer komprimering med begrenset tap og en ny koder, som kan gi mer effektiv komprimering. Denne versjonen introduserer også dataavhengigheter som kan begrense datastrømkapasiteten til komprimerere på FPGA. Denne masteroppgaven utforsker en av de mindre dokumenterte tilnærmingene for å implementere en komprimerer med høy datastrømkapasitet til tross for disse dataavhengighetene.   En CCSDS 123.0-B-2 komprimerer er implementert for FPGA. Implementasjonen er verifisert ved å simulere kompresjon og sammenligne resultatene mot en verifisert modell. Et testsett på 2000 tilfeldig genererte bilder og kompresjonskonfigurasjoner er blant verifikasjonstestene. Komprimereren har blitt brukt til å komprimere bilder på HYPSO-1 satellitten i verdensrommet, og komprimeringskorrektheten er verifisert. Den kan komprimere et HYPSO-1 bilde på 1,2 sekunder.  Implementasjonen har en datastrømkapasitet på 110 millioner punktprøver i sekundet, eller 1.76 Gb/s, på en Kintex XCKU040 FPGA. Dette dokumenterer grensene for denne dataavhengighetstilnærmingen. Sammenlignet med andre tilnærminger gir den en avveining av lavere datastrømkapasitet men lavere bruk av FPGA ressurser. Den har 39\% av datastrømkapasiteten til en lignende implementasjon, men bruker bare 39\% så mange LUT, 17\% FF, 13\% DSP og 37\% BRAM. Dette er den laveste ressursbruken blant implementasjoner med lignende egenskaper og er relevant for systemer med mindre eller tettpakkede FPGAer, som HYPSO-1.  Dette er den første publiserte implementasjonen som bruker denne dataavhengighetstilnærmingen som implementerer en hel kompressor og som er testet på maskinvare. Datastrømkapasiteten er forskjellig fra resultatet til en implementasjon med samme tilnærming som ble evaluert med High-Level Synthesis (HLS).},
  langid = {english},
  annotation = {Accepted: 2024-10-15T17:20:54Z},
  file = {/Users/aasmundnorsett/Zotero/storage/Q8WCPWG2/Vorhaug - 2024 - Hyperspectral Image Compression Accelerator On FPGA Using CCSDS 123.0-B-2.pdf}
}

